{
  "easings": {
    "standard": { "$value": "cubic-bezier(0.25, 1, 0.5, 1)", "$type": "cubic-bezier", "role": "default-easing" },
    "color": { "$value": "150ms", "$type": "duration", "role": "color-transition-duration" },
    "transform": { "$value": "0.15s cubic-bezier(0.25, 1, 0.5, 1)", "$type": "composite", "role": "transform-transition" }
  },
  "animations": {
    "crt-flicker": { "timing": "step-end 60ms", "purpose": "Theme toggle white overlay flash" },
    "blink-cursor": { "timing": "1s step-end infinite", "purpose": "Terminal cursor blink" },
    "crt-scroll": { "timing": "8s linear infinite", "purpose": "Scanline vertical scroll" },
    "typewriter": { "timing": "220ms per line", "purpose": "Terminal line reveal delay between each typed line" },
    "fade-in-up": { "duration": "0.3s", "easing": "cubic-bezier(0.25, 1, 0.5, 1)", "purpose": "Staggered page-load entrance" },
    "reveal-stagger": { "delays": ["0s", "0.1s", "0.2s", "0.3s", "0.4s", "0.5s", "0.6s", "0.7s", "0.8s"] },
    "phosphor-afterglow": { "duration": "2.5s", "easing": "ease-out", "purpose": "NeXT terminal text glow fade" },
    "accordion-rotate": { "duration": "0.15s", "easing": "cubic-bezier(0.25, 1, 0.5, 1)", "purpose": "Accordion chevron rotation" },
    "toast-enter": { "duration": "0.3s", "easing": "cubic-bezier(0.25, 1, 0.5, 1)", "purpose": "Toast slide-in from bottom-right" },
    "toast-exit": { "duration": "0.2s", "easing": "cubic-bezier(0.25, 1, 0.5, 1)", "purpose": "Toast fade-out and slide" },
    "skeleton-pulse": { "duration": "1.5s", "easing": "ease-in-out", "iteration": "infinite", "purpose": "Skeleton loading placeholder pulse" },
    "status-blink": { "duration": "2s", "easing": "step-end", "iteration": "infinite", "purpose": "Error status dot blink" },
    "dot-pulse": { "duration": "2s", "easing": "ease-out", "iteration": "infinite", "purpose": "Active accent dot pulse" }
  }
}
