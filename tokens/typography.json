{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "families": {
    "display": { "fontFamily": "Silkscreen, system-ui, sans-serif", "fontWeight": 700 },
    "body":    { "fontFamily": "system-ui, -apple-system, Segoe UI, sans-serif", "fontWeight": 400 },
    "mono":    { "fontFamily": "VT323, Courier New, monospace", "fontWeight": 400 }
  },
  "scale": {
    "step-1":  { "size": "0.75rem",   "weight": 400, "lineHeight": "1",   "purpose": "Labels, captions, micro text" },
    "step-2":  { "size": "0.875rem",  "weight": 400, "lineHeight": "1.4", "purpose": "Body small, table cells" },
    "step-3":  { "size": "1rem",      "weight": 400, "lineHeight": "1.5", "purpose": "Body default" },
    "step-4":  { "size": "1.125rem",  "weight": 400, "lineHeight": "1.5", "purpose": "Body large" },
    "step-5":  { "size": "1.25rem",   "weight": 700, "lineHeight": "1.3", "purpose": "Title" },
    "step-6":  { "size": "1.5rem",    "weight": 700, "lineHeight": "1.3", "purpose": "Headline small" },
    "step-7":  { "size": "2rem",      "weight": 700, "lineHeight": "1.2", "purpose": "Headline" },
    "step-8":  { "size": "6rem",      "weight": 700, "lineHeight": "1",   "purpose": "Display (hero only)" }
  },
  "semantic": {
    "display": { "step": "step-8",  "purpose": "Hero headline 'YOUR' only. Silkscreen 700." },
    "headline": { "step": "step-6 to step-7", "purpose": "Section headings. Silkscreen 700." },
    "title": { "step": "step-5", "purpose": "Sub-section headings, card titles. Silkscreen 700." },
    "body": { "step": "step-2 to step-4", "maxLineLength": "65-75ch", "purpose": "Paragraph copy. system-ui 400." },
    "label": { "step": "step-1", "tracking": "0.05em", "transform": "uppercase", "purpose": "Nav links, badges, tech tags. Silkscreen 700." },
    "mono": { "step": "step-2 to step-3", "purpose": "Terminal output, prompts. VT323 400." }
  }
}
